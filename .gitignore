# ─── Binary / Archive files (never track these in Git) ─────────────────────
*.zip
*.rar
*.7z
*.tar.gz

# ─── Xilinx ISE generated files ─────────────────────────────────────────────
*.bit          # Bitstream
*.mcs          # Programming file
*.ncd          # Netlist
*.ngc          # NGC netlist
*.ngd          # Native generic database
*.pcf          # Physical constraints (generated)
*.xwbt         # ISE project temp
*.gise         # ISE GUI state
*.ise          # ISE project file (binary)
*.xise         # ISE project (keep .xise only if text-based)
*.log          # Simulation / synthesis logs
*.twr          # Timing report
*.twx          # Timing XML
*.bgn          # Bitgen log
*.bld          # Build log
*.drc          # DRC report
*.pad          # PAD report
*.par          # PAR report
*.ptwx         # Post-translate timing
*.map          # Map report
*.mrp          # Map report
*.xrpt         # XML report
*.srp          # Synthesis report
*.syr          # Synthesis report
*_summary.html # ISE summary HTML
*_envsettings.html
xst/           # XST temp directory
iseconfig/     # ISE config
xlnx_auto_*/   # Auto-generated ISE directories

# ─── Vivado generated files ──────────────────────────────────────────────────
*.runs/
*.cache/
*.hw/
*.ip_user_files/
*.sim/
*.gen/
*.jou          # Vivado journal
*.str          # Vivado strategy
.Xil/          # Vivado temp

# ─── Simulation outputs ──────────────────────────────────────────────────────
*.vcd          # Waveform dumps (large — use GTKWave locally)
*.shm/         # Cadence simulation database
*.trn          # Cadence transcript
simv           # VCS compiled binary
simv.daidir/
csrc/
ucli.key
DVEfiles/
inter.vpd

# ─── Cadence / Xcelium ───────────────────────────────────────────────────────
INCA_libs/
waves.shm/
*.diag

# ─── OS junk ────────────────────────────────────────────────────────────────
.DS_Store      # Mac
Thumbs.db      # Windows
desktop.ini
